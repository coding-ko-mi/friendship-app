# =============================================================================
# .env.example — шаблон переменных окружения.
#
# ИСПОЛЬЗОВАНИЕ:
#   cp .env.example .env
#   # Заполни реальные значения в .env
#   # НИКОГДА не коммить .env в Git — только этот .env.example
#
# Все секреты сгенерировать так:
#   openssl rand -hex 32
# =============================================================================

# --- PostgreSQL ---
# Используется в docker-compose.yml (POSTGRES_*) и в DATABASE_URL.
POSTGRES_USER=friendship
POSTGRES_PASSWORD=              # ОБЯЗАТЕЛЬНО: openssl rand -hex 16
POSTGRES_DB=friendship

# URL для подключения SQLAlchemy (asyncpg-драйвер).
# В compose имя хоста = имя сервиса postgres.
# Замени POSTGRES_PASSWORD на значение из POSTGRES_PASSWORD выше.
DATABASE_URL=postgresql+asyncpg://friendship:POSTGRES_PASSWORD@postgres:5432/friendship

# --- Redis ---
# В compose имя хоста = имя сервиса redis.
REDIS_URL=redis://redis:6379/0

# --- JWT ---
# Генерация: openssl rand -hex 32
JWT_SECRET=                     # ОБЯЗАТЕЛЬНО: длинная случайная строка
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Telegram ---
# Получить у @BotFather (/newbot или /mybot → API Token)
TELEGRAM_BOT_TOKEN=             # ОБЯЗАТЕЛЬНО: формат 123456789:AABBcc...

# --- Mini App ---
# URL твоего задеплоенного фронта (HTTPS обязателен — требование Telegram).
# Пример: https://app.example.com/
MINI_APP_URL=                   # ОБЯЗАТЕЛЬНО: https://твой-домен/

# --- Webhook бота ---
# Полный HTTPS URL, куда Telegram будет слать апдейты.
# Должен совпадать с настройкой в app/bot/main.py.
# Пример: https://app.example.com/webhook
WEBHOOK_URL=                    # ОБЯЗАТЕЛЬНО: https://твой-домен/webhook
# Путь webhook внутри приложения (без домена)
WEBHOOK_PATH=/webhook
# Хост и порт, на которых aiogram поднимает aiohttp-сервер для приёма webhook
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
# Секрет для проверки подлинности webhook-запросов от Telegram.
# Сгенерируй: openssl rand -hex 32  →  на проде ОБЯЗАТЕЛЬНО задать.
# Без него любой может подделать апдейт, угадав/узнав WEBHOOK_URL.
WEBHOOK_SECRET=                 # ОБЯЗАТЕЛЬНО на проде

# --- Продуктовые параметры ---
# Размер компании, при котором все участники получают FULL_HOUSE
FULL_HOUSE_SIZE=8

# Как долго skip хранится в Redis (дней)
DISCOVERY_SKIP_TTL_DAYS=14

# Размер страницы ленты подбора
DISCOVERY_PAGE_SIZE=20

# TTL ожидающего фото (секунд). 86400 = 24 часа.
PENDING_PHOTO_TTL_SECONDS=86400

# Имя Redis-списка для событий API→бот
EVENTS_QUEUE_KEY=bot:events
