# Скопируй в .env и заполни:  cp .env.example .env

# --- База данных ---
DATABASE_URL=postgresql+asyncpg://friendship:friendship@localhost:5432/friendship

# --- JWT ---
# Генерация: openssl rand -hex 32
# НИКОГДА не коммить реальный секрет в git!
JWT_SECRET=замени_на_случайную_длинную_строку

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Telegram ---
# Токен бота из @BotFather — нужен для валидации Mini App initData и запуска бота
TELEGRAM_BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff

# --- Бот (модуль «Бот (aiogram)») ---
# URL Telegram Mini App — HTTPS-домен фронтенда (требование Telegram для web_app кнопок)
MINI_APP_URL=https://example.com/app
# TTL ожидающего фото в Redis (секунды). По умолчанию 24 часа.
PENDING_PHOTO_TTL_SECONDS=86400
# Имя Redis-списка для событий бэкенд → бот (мэтч, результат голосования).
EVENTS_QUEUE_KEY=bot:events
