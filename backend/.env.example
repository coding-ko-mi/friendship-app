# Скопируй в .env и заполни:  cp .env.example .env

# --- База данных ---
DATABASE_URL=postgresql+asyncpg://friendship:friendship@localhost:5432/friendship

# --- JWT ---
# Генерация: openssl rand -hex 32
# НИКОГДА не коммить реальный секрет в git!
JWT_SECRET=замени_на_случайную_длинную_строку

# --- Telegram ---
# Токен бота из @BotFather — нужен для валидации Mini App initData
TELEGRAM_BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff
